{
    "layer": "bottom",

    "modules-center": ["clock", "hyprland/workspace", "pulseaudio", "network", "battery"],

    "clock": {
        "interval": 60,
        "format": "{:%H:%M}",
    },
    "hyprland/workspace": {
        "format": "{name}",
        "format-icons": {
            "1": "1",
        },
        "persistent-workspaces": {
            "*": 1,
        },
    },
    "pulseaudio": {
    }


}
